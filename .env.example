# ─────────────────────────────────────────────────────────────────────────────
# Stock Prediction — environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# All env vars are loaded by `src/config/settings.py` via pydantic-settings.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=stock-prediction
APP_ENV=development            # development | staging | production
APP_DEBUG=true
APP_VERSION=0.1.0

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
API_RATE_LIMIT_PER_MINUTE=60

# ── Database (PostgreSQL + TimescaleDB) ──────────────────────────────────────
# A single DATABASE_URL is parsed into async and sync engines by settings.py.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_prediction
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=stock-prediction
MLFLOW_ARTIFACT_LOCATION=./mlruns

# ── Prefect (optional, only for production orchestration) ────────────────────
# PREFECT_API_URL=http://localhost:4200/api

# ── Paths ────────────────────────────────────────────────────────────────────
# Resolved relative to project root by settings.py
DATA_DIR=data
RAW_DATA_DIR=data/raw
INTERIM_DATA_DIR=data/interim
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=models
LOGS_DIR=logs

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                 # json | console
LOG_ROTATION=100 MB
LOG_RETENTION=30 days

# ── ML / training ────────────────────────────────────────────────────────────
RANDOM_SEED=42
DEFAULT_MARKET=jp               # jp | us (extensible)
DEFAULT_HORIZON_DAYS=5          # forecast horizon for direction labels
